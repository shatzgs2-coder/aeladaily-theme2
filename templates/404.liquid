{%- comment -%}
  404 - Page Not Found template
{%- endcomment -%}

<div class="page-404">
  <div class="page-404__inner">
    <p class="page-404__eyebrow">404</p>
    <h1 class="page-404__title">{{ 'general.404.title' | t }}</h1>
    <p class="page-404__subtext">{{ 'general.404.subtext' | t }}</p>
    <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary page-404__link">
      {{ 'general.404.link' | t }}
    </a>
  </div>
</div>

<style>
  .page-404 {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    padding: 4rem 1.5rem;
    text-align: center;
  }
  .page-404__eyebrow {
    font-size: 6rem;
    font-weight: 300;
    color: var(--color-primary, #8B7355);
    margin: 0 0 1rem;
    line-height: 1;
  }
  .page-404__title {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 2rem;
    color: var(--color-text, #3D3530);
    margin: 0 0 0.5rem;
  }
  .page-404__subtext {
    color: var(--color-text, #3D3530);
    opacity: 0.7;
    margin: 0 0 2rem;
  }
  .page-404__link {
    display: inline-block;
    padding: 0.875rem 2.5rem;
    background: var(--color-primary, #8B7355);
    color: #fff;
    text-decoration: none;
    border-radius: 2px;
    font-size: 0.875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: background 0.3s ease;
  }
  .page-404__link:hover {
    background: var(--color-text, #3D3530);
  }
</style>
