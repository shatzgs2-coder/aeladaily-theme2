{%- comment -%}
  Password page template - shown when store is password protected
{%- endcomment -%}

<div class="password-page">
  <div class="password-page__inner">
    <h1 class="password-page__heading">{{ shop.name }}</h1>
    <p class="password-page__message">{{ 'general.password_page.opening_soon' | t: shop_name: shop.name }}</p>

    {% form 'storefront_password' %}
      <div class="password-form">
        <input
          type="password"
          name="password"
          class="password-form__input"
          placeholder="{{ 'general.password_page.password_placeholder' | t }}"
          autocomplete="current-password"
        >
        <button type="submit" class="password-form__submit btn btn--primary">
          {{ 'general.password_page.submit' | t }}
        </button>
      </div>
      {% if form.errors %}
        <p class="password-form__error">{{ form.errors | default_errors }}</p>
      {% endif %}
    {% endform %}

    <p class="password-page__owner">
      {{ 'general.password_page.admin_link_html' | t: link: '/admin' }}
    </p>
  </div>
</div>

<style>
  .password-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 2rem 1.5rem;
    background: var(--color-bg, #F5F1EA);
  }
  .password-page__inner {
    text-align: center;
    max-width: 480px;
  }
  .password-page__heading {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 2.5rem;
    color: var(--color-text, #3D3530);
    margin: 0 0 1rem;
  }
  .password-page__message {
    color: var(--color-text, #3D3530);
    opacity: 0.7;
    margin: 0 0 2rem;
  }
  .password-form {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .password-form__input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border, #E8E0D5);
    background: #fff;
    font-size: 1rem;
    border-radius: 2px;
  }
  .password-form__submit {
    padding: 0.75rem 2rem;
    background: var(--color-primary, #8B7355);
    color: #fff;
    border: none;
    cursor: pointer;
    border-radius: 2px;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .password-form__error {
    color: #c00;
    font-size: 0.875rem;
  }
  .password-page__owner {
    font-size: 0.8rem;
    opacity: 0.5;
    margin-top: 2rem;
  }
  .password-page__owner a {
    color: inherit;
    text-decoration: underline;
  }
</style>
